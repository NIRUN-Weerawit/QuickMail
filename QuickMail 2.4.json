      "parameters": {
        "jsCode": "function makeJsonCompatible(text) { \n  return JSON.stringify(text); \n}\nfunction cleanEmail(text) {\n  return text\n    .replace(/&nbsp;/g, \" \")\n    .replace(/&ndash;/g, \"-\")\n    .replace(/&quot;/g, '\"')\n    .replace(/\\r/g, \"\\n\")\n    .replace(/\\n{3,}/g, \"\\n\\n\")\n    .trim();\n}\n\nconst rawText = $input.first().json.text;\nconst subject = $input.first().json.subject;\nconst sender_name = $input.first().json.from.value[0].name;\nconst sender_email = $input.first().json.from.value[0].address\n// const date = $input.first().json.date;\nconst receiver = $input.first().json.headers['delivered-to'];\n\n// No JSON.stringify here\n// const prompt = makePrompt(rawText);\nconst safeText = makeJsonCompatible(rawText);\n// const safePrompt = makeJsonCompatible(prompt);\nconst safeSubject = makeJsonCompatible(subject);\nconst safeSenderName = makeJsonCompatible(sender_name);\nconst safeSenderEmail = makeJsonCompatible(sender_email);\nconst safeReceiver = makeJsonCompatible(receiver)\n// const safeDate = makeJsonCompatible(date);\nreturn [\n  {\n    json: {\n      content: safeText,\n      // prompt: safePrompt,\n      subject: safeSubject,\n      senderEmail: safeSenderEmail,\n      senderName: safeSenderName,\n      receiver: safeReceiver,\n      date: makeJsonCompatible($now),\n      sessionId: makeJsonCompatible($input.first().json.id),\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
